{
  "name": "terminal-talk",
  "version": "0.3.9",
  "description": "Hands-free voice workflow for Claude Code: TTS playback for Claude responses + 'hey jarvis' highlight-to-speak. Free by default (Edge TTS + openWakeWord).",
  "homepage": "https://github.com/benfrancisburns-creator/terminal-talk",
  "license": "MIT",
  "private": true,
  "scripts": {
    "test": "node scripts/run-tests.cjs",
    "test:verbose": "node scripts/run-tests.cjs --verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm test && npm run test:e2e",
    "test:coverage": "c8 --reporter=text --reporter=lcov node scripts/run-tests.cjs --logic-only",
    "test:palette-diff": "node scripts/palette-pixel-diff.cjs",
    "test:palette-diff:update": "node scripts/palette-pixel-diff.cjs --update",
    "verify-voices": "node scripts/verify-voices.cjs",
    "sonar": "bash scripts/run-sonar.sh",
    "lint": "eslint app scripts docs/ui-kit eslint.config.js",
    "lint:fix": "eslint app scripts docs/ui-kit eslint.config.js --fix",
    "knip": "knip",
    "start": "node -e \"console.log('Run install.ps1 first, then start via the Startup shortcut or wscript scripts/start-toolbar.vbs')\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "tts",
    "text-to-speech",
    "wake-word",
    "voice",
    "edge-tts",
    "openwakeword",
    "electron",
    "windows",
    "accessibility"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "c8": "^10.1.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "knip": "^6.5.0"
  }
}

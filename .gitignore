# Node
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc

# Runtime state (shouldn't be committed)
app/listening.state
app/node_modules/

# User queue + logs (created at install time, not tracked)
queue/
*.log
*.wav
*.mp3
*.partial

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp

# Playwright artefacts (tests themselves ARE tracked — these are outputs)
/test-results/
/playwright-report/
/playwright/.cache/

# render-mocks.cjs and palette-pixel-diff.cjs scratch output
/.tmp-mocks/
/.tmp-pixel-diff/
/coverage/

# SonarQube local scan artefacts + token
.sonarqube-token
.scannerwork/
.tmp-*.json
